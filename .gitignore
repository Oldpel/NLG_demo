# ============================================================
# [Security] 数据与敏感文件拦截规则
# ============================================================

# 1. 拦截所有业务数据与分析报告（核心防线）
data/raw*/
data/*.csv
data/*.json
data/*.txt
M1_list/data/

# 2. 拦截模型权重与日志文件
checkpoints/
jcheckpoints/
*.log
*.png

# 3. 拦截 Python 编译缓存与环境文件（提升可维护性）
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
.env
